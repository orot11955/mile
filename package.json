{
  "name": "mile",
  "version": "0.1.0",
  "private": true,
  "description": "mile project orchestration for web, server, test, and compose deployment.",
  "scripts": {
    "install:all": " yarn --cwd mile-server install &&  yarn --cwd mile-web install",
    "dev": "docker compose up -d postgres redis && yarn server:dev",
    "dev:infra": "docker compose up -d postgres redis",
    "dev:web": "yarn --cwd mile-web dev",
    "dev:server": "yarn --cwd mile-server start:dev",
    "build": "yarn server:build && yarn web:build",
    "test": "yarn server:test",
    "test:e2e": "yarn server:test:e2e",
    "lint": "yarn server:lint && yarn web:lint",
    "server:generate": "yarn --cwd mile-server prisma:generate",
    "server:migrate": "yarn --cwd mile-server prisma:migrate",
    "server:studio": "yarn --cwd mile-server prisma:studio",
    "server:dev": "yarn --cwd mile-server start:dev",
    "server:build": "yarn --cwd mile-server build",
    "server:test": "yarn --cwd mile-server test",
    "server:test:e2e": "yarn --cwd mile-server test:e2e",
    "server:lint": "yarn --cwd mile-server lint",
    "web:build": "yarn --cwd mile-web build",
    "web:lint": "yarn --cwd mile-web lint",
    "compose:build": "docker compose build",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "yarn@1.22.22"
}